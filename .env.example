# AI classification (set one or both — Gemini is checked first)
GEMINI_API_KEY=         # get a free key at aistudio.google.com
GEMINI_MODEL=gemini-2.0-flash-lite   # optional override
ANTHROPIC_API_KEY=      # optional — Claude Haiku fallback

# Email alerts and digest
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=          # Gmail app password (not your login password)
ALERT_EMAIL=you@example.com
